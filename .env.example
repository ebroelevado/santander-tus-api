# Puerto del servidor (default: 3000)
PORT=3000

# URL pública para documentación Swagger (default: http://localhost:PORT)
BASE_URL=https://tus-api.example.com

# Redis Connection URL (L2 Cache)
REDIS_URL=redis://user:password@host:port

# INS4G API credentials (Insforge real-time data)
INS4G_URL=http://your-ins4g-host:7130
INS4G_KEY=your_ins4g_api_key_here
